# ============================================================================
# FOOD FACTORY POS - Environment Variables Template
# ============================================================================
# Copy this to .env and fill in your values, then add them to Vercel
# Go to: Vercel Dashboard → Settings → Environment Variables
# ============================================================================

VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_PROJECT_NAME=Food Factory POS
VITE_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
VITE_APPWRITE_STORAGE_NAME=product-images
VITE_APPWRITE_STORAGE_ID=product-images
